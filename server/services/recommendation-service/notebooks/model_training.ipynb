 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Recommendation Engine Model Training\n",
    "\n",
    "This notebook demonstrates how to load, preprocess, and train the recommendation models using Pandas and Scikit-learn."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.metrics.pairwise import linear_kernel, cosine_similarity\n",
    "import matplotlib.pyplot as plt\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "products_df = pd.read_csv('../datasets/products.csv')\n",
    "interactions_df = pd.read_csv('../datasets/user_interactions.csv')\n",
    "ratings_df = pd.read_csv('../datasets/ratings.csv')\n",
    "\n",
    "print(\"Products shape:\", products_df.shape)\n",
    "print(\"Interactions shape:\", interactions_df.shape)\n",
    "print(\"Ratings shape:\", ratings_df.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Content-Based Filtering (Products)\n",
    "We use TF-IDF to convert product tags and categories into vectors, then compute cosine similarity."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "products_df['content'] = products_df['category'].fillna('') + ' ' + products_df['tags'].fillna('')\n",
    "\n",
    "tfidf = TfidfVectorizer(stop_words='english')\n",
    "tfidf_matrix = tfidf.fit_transform(products_df['content'])\n",
    "\n",
    "cosine_sim = linear_kernel(tfidf_matrix, tfidf_matrix)\n",
    "print(\"Similarity matrix shape:\", cosine_sim.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Collaborative Filtering (Users)\n",
    "We build a user-item matrix from ratings and infer missing data using cosine similarity."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "user_item_matrix = ratings_df.pivot_table(index='user_id', columns='product_id', values='rating').fillna(0)\n",
    "user_sim = cosine_similarity(user_item_matrix)\n",
    "print(\"User similarity matrix shape:\", user_sim.shape)"
   ]
  }
 ],
